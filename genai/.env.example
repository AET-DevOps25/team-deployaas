# GenAI Service Configuration

# OpenAI API Configuration (optional - for cloud-based inference)
# OPENAI_API_KEY=your_openai_api_key_here

# Local Model Configuration
LOCAL_MODEL_PATH=/app/models

# Service Configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8084
LOG_LEVEL=INFO

# Model Settings
DEFAULT_MODEL=local  # or "openai" or "advanced"
MAX_TOKENS=1000
TEMPERATURE=0.7
